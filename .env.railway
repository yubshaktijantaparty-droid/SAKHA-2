# Railway Environment Variables Configuration
# Add these to Railway project settings or use railway.json

# Application Environment
ENVIRONMENT=production
DEBUG_MODE=false

# Database - Use MongoDB Atlas or Railway MongoDB
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=${MONGODB_URI}
MONGODB_DB_NAME=sakha_premium_db

# Security Keys
SECRET_KEY=${SECRET_KEY}
JWT_SECRET=${JWT_SECRET}

# OpenRouter API Keys (AI Model Provider)
OPENROUTER_OWL_ALPHA_API_KEY=${OPENROUTER_OWL_ALPHA_API_KEY}
OPENROUTER_PREMIUM_API_KEY=${OPENROUTER_PREMIUM_API_KEY}

# Other API Keys (Optional)
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
GEMINI_API_KEY=${GEMINI_API_KEY}
DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}

# CORS Settings
CORS_ORIGINS=https://yubshaktijantaparty-droid.github.io,http://localhost:5173,http://localhost:3000
