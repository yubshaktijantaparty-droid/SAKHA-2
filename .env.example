# SAKHA AI - Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env file to GitHub - keep API keys secret!

# ==================== DEPLOYMENT SETTINGS ====================
ENVIRONMENT=development
DEBUG_MODE=False
LOG_LEVEL=INFO

# ==================== FRONTEND ====================
VITE_API_URL=http://localhost:8000
VITE_REPO_NAME=sakha-ai
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ==================== BACKEND SERVER ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ==================== DATABASE ====================
# MongoDB Atlas (Recommended - Free tier available)
# Sign up: https://www.mongodb.com/cloud/atlas
DATABASE_TYPE=mongodb
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sakha_db?retryWrites=true&w=majority
MONGODB_DB_NAME=sakha_db

# ==================== AI SERVICES ====================
# Required: Choose at least ONE provider
# Get API keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - DeepSeek: https://platform.deepseek.com
# - Google Gemini: https://ai.google.dev

OPENAI_API_KEY=sk-your-actual-api-key-here
OPENAI_MODEL=gpt-4-turbo

DEEPSEEK_API_KEY=sk-your-actual-api-key-here
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=your-actual-api-key-here
GEMINI_MODEL=gemini-pro

DEFAULT_AI_PROVIDER=openai
AI_TIMEOUT=30

# ==================== SUPABASE (Authentication) ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ==================== SECURITY & CORS ====================
# Development - Allow localhost
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Production - Update with actual domains
# CORS_ORIGINS=https://yourusername.github.io,https://your-backend-url.com

CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ==================== API RATE LIMITING ====================
API_RATE_LIMIT=100
API_TIMEOUT=30
MAX_REQUEST_SIZE=10485760  # 10 MB

# ==================== LOGGING ====================
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760  # 10 MB
LOG_BACKUP_COUNT=5

