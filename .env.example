# SAKHA AI - Environment Configuration Template
# Copy this file to .env and fill in your values for local development
# NEVER commit .env file to GitHub - keep API keys secret!

# ==================== DEPLOYMENT MODE ====================
# Options: development, production-github-pages, production-railway
DEPLOYMENT_MODE=development

# ==================== FRONTEND (GitHub Pages / Development) ====================
# Local development
VITE_API_URL=http://localhost:8000
VITE_REPO_NAME=sakha-ai

# For GitHub Pages production, set to your Render backend URL:
# VITE_API_URL=https://sakha-backend-xxxx.onrender.com

# ==================== BACKEND (FastAPI) ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ENVIRONMENT=development
DEBUG_MODE=True
LOG_LEVEL=INFO

# ==================== AI SERVICES ====================
# Choose at least one AI provider and add your API keys
# Get keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - DeepSeek: https://platform.deepseek.com
# - Google Gemini: https://ai.google.dev

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-pro

# Default Provider (openai, deepseek, or gemini)
DEFAULT_AI_PROVIDER=openai
AI_TIMEOUT=30

# ==================== DATABASE ====================
# MongoDB Atlas (Recommended - Free tier available)
# Sign up: https://www.mongodb.com/cloud/atlas
DATABASE_TYPE=mongodb

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sakha_db?retryWrites=true&w=majority
MONGODB_DB_NAME=sakha_db

# Or Local MongoDB (for development)
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB_NAME=sakha_db

# ==================== CORS & SECURITY ====================
# Development - Allow localhost
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Production - Update with your GitHub Pages URL
# CORS_ORIGINS=https://YOUR_USERNAME.github.io,https://sakha-backend-xxxx.onrender.com

CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ==================== API CONFIGURATION ====================
API_RATE_LIMIT=100
API_TIMEOUT=30
MAX_REQUEST_SIZE=10485760  # 10 MB

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760  # 10 MB
LOG_BACKUP_COUNT=5

# ==================== EMAIL (Optional) ====================
# For error notifications and alerts
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# ==================== GITHUB PAGES DEPLOYMENT ====================
# When deploying to GitHub Pages + Render:
# 1. Frontend goes to GitHub Pages (automatic via GitHub Actions)
# 2. Backend goes to Render (configure in Render dashboard)
# 3. Set VITE_API_URL to your Render backend URL in GitHub Secrets
# 4. See GITHUB_PAGES_DEPLOYMENT.md for full instructions

# GitHub Actions Secrets to configure:
# - VITE_API_URL: https://sakha-backend-xxxx.onrender.com
# - VITE_REPO_NAME: sakha-ai (your repository name)
# - RENDER_SERVICE_ID: (from Render)
# - RENDER_DEPLOY_KEY: (from Render)

# ==================== RAILWAY DEPLOYMENT (Alternative) ====================
# If deploying to Railway instead of GitHub Pages:
# RAILWAY_API_KEY=your-railway-token-here
# RAILWAY_SERVICE_NAME=sakha-ai


# ==================== BOT SETTINGS ====================
BOT_NAME=SAKHA
BOT_OWNER=Pranab Goswami
BOT_OWNER_ID=919999999999
BOT_PREFIX=.
DEBUG_MODE=False
LOG_LEVEL=INFO

# ==================== DATABASE ====================
DATABASE_TYPE=mongodb
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sakha?retryWrites=true&w=majority
MONGODB_DB_NAME=sakha_db

# ==================== AI SERVICES ====================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo
DEFAULT_AI_PROVIDER=openai
AI_TIMEOUT=30

# ==================== WHATSAPP ====================
WHATSAPP_SESSION_NAME=SAKHA_SESSION
WHATSAPP_AUTH_PATH=./whatsapp_auth

# ==================== SERVER ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ENVIRONMENT=development

# ==================== SECURITY ====================
SECRET_KEY=generate-a-secure-random-string-here
JWT_SECRET=your-jwt-secret-key
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ==================== FEATURES ====================
ENABLE_STUDY_ASSISTANT=True
ENABLE_BUSINESS_ASSISTANT=True
ENABLE_PRODUCTIVITY=True
ENABLE_ADMIN_COMMANDS=True
ENABLE_AUTO_MODERATION=True
